# Gap Assessment Agent — Environment Variables
#
# Copy this file to .env (repo root) and fill in your values.
# .env is git-ignored; NEVER commit real credentials.

# ── GCP / Vertex AI ──────────────────────────────────────────────────────────
# Project that owns both the Discovery Engine datastore and the Vertex AI
# endpoint used by the LLM agents.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region for Vertex AI model inference (e.g. us-central1, europe-west4).
# ADK reads this variable to route LLM calls — must be a Vertex AI region,
# NOT a Discovery Engine multi-region like "us" or "global".
GOOGLE_CLOUD_LOCATION=us-central1

# Route LLM calls through Vertex AI (required for ADK + Gemini).
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ── LLM model ────────────────────────────────────────────────────────────────
# Gemini model name as understood by Vertex AI, e.g.:
#   gemini-2.0-flash
#   gemini-2.0-flash-001
#   gemini-1.5-pro
MODEL_NAME=gemini-2.0-flash

# ── Discovery Engine ─────────────────────────────────────────────────────────
# The DE datastore ID (not the full resource path — just the ID part, e.g.
# my-datastore_1234567890).  The tool reads this at call time via os.getenv.
DATASTORE_ID=your-datastore-id

# DE store location — a DE multi-region or region string (e.g. "us", "global",
# "us-central1").  Intentionally separate from GOOGLE_CLOUD_LOCATION because
# the DE API endpoint and the Vertex AI endpoint use different location formats.
DATASTORE_LOCATION=us
