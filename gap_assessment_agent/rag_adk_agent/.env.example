# ---------------------------------------------------------------
# Sample environment configuration for the RAG ADK Agent
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------

# Use Vertex AI as the backend for Google GenAI calls
GOOGLE_GENAI_USE_VERTEXAI=

# GCP project ID (auto-detected via Application Default Credentials if unset)
GOOGLE_CLOUD_PROJECT=

# Vertex AI region
GOOGLE_CLOUD_LOCATION=

# Vertex AI Search (Discovery Engine) datastore settings
DATASTORE_ID=
DATASTORE_LOCATION=
